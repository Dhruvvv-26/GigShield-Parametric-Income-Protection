# ═══════════════════════════════════════════════════════════════════════════════
# GigShield — Environment Variables (Phase 3: API Integration)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# All APIs below have free tiers sufficient for hackathon use.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gigshield
DB_USER=gigshield
DB_PASSWORD=gigshield_secure_2026

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secure_2026@localhost:6379/0

# ── Redpanda / Kafka ──────────────────────────────────────────────────────────
REDPANDA_BROKERS=localhost:9092

# ═══════════════════════════════════════════════════════════════════════════════
# 100% FREE API STACK
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1. OpenWeatherMap (Weather: Rain, Temp, Wind) ─────────────────────────────
# Free tier: 1,000 calls/day. We use ~96/day (6 cities × 15-min intervals).
# Signup: https://openweathermap.org/api
OWM_API_KEY=cb2a63918460b8dbcff75147ea727f15

# ── 2. WAQI (Air Quality Index — CPCB sensor data) ───────────────────────────
# Free tier: 1,000 calls/day. We use ~144/day (6 cities × 60-min intervals).
# Signup: https://aqicn.org/data-platform/token/
WAQI_API_KEY=dbb5b4fa605d51dcaf10a97e85344a6230b47b3e

# ── 3. WeatherAPI.com (Severe Weather Alerts — IMD Red Alerts) ────────────────
# Free tier: 1,000,000 calls/month. We use ~288/day.
# Signup: https://www.weatherapi.com/signup.aspx
WEATHERAPI_KEY=f980148bd5b24497878192824260204 

# ── 4. IPinfo.io (Server-side IP Geolocation for Fraud Detection) ─────────────
# Free tier: 50,000 requests/month. We use 1 call per claim submission.
# Signup: https://ipinfo.io/signup
IPINFO_TOKEN=825a6f57606672

# ── 5. OneSignal (Push Notifications to Riders) ──────────────────────────────
# Free tier: Unlimited mobile push. 10K web push.
# Signup: https://onesignal.com
ONESIGNAL_APP_ID=22569235-701c-4c3b-a7f7-19c1c90ec4e1
ONESIGNAL_REST_KEY=os_v2_app_ejljenlqdrgdxj7xdha4sdwe4hui6wdqlseebyuo7ktfd6kdvsx4wsicf4askaihdq6i3rdxoouzf5kxoelvaf2bidn5bbopk3lp2ma

# ── 6. Supabase (Worker App Authentication — Phone OTP) ──────────────────────
# Free tier: 50K MAU, unlimited API calls, built-in Phone Auth.
# Test Phone Numbers: Configure in Supabase Dashboard > Auth > Phone Auth
#   +919999900001 → OTP: 123456
# Signup: https://supabase.com
SUPABASE_URL=https://isosnodmzqvaedujnqkc.supabase.co
SUPABASE_ANON_KEY=sb_publishable_vlKpSwhUAitdGgXVYN9Jzg_MBFNH3Od

# Worker app uses these as EXPO_PUBLIC_ prefixed vars:
EXPO_PUBLIC_SUPABASE_URL=https://isosnodmzqvaedujnqkc.supabase.co
EXPO_PUBLIC_SUPABASE_ANON=sb_publishable_vlKpSwhUAitdGgXVYN9Jzg_MBFNH3Od

# ── 7. Razorpay (UPI Payouts — Test Mode) ────────────────────────────────────
# Test mode: No charges, simulated payouts.
# Signup: https://razorpay.com
RAZORPAY_KEY_ID=rzp_test_SXlxoGc4KsKJE7
RAZORPAY_KEY_SECRET=eMm0RoRjBhiuPuD0cCPyP63Q

# ── 8. CartoDB / OpenStreetMap (Admin Dashboard Map) ──────────────────────────
# No API key required. Uses CartoDB Dark Matter tiles (free, raster).
# URL: https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=gigshield_secure_demo_key_2026

# ── ML Service ────────────────────────────────────────────────────────────────
ML_MODEL_DIR=/app/ml/models

# ── Inter-Service Routing ─────────────────────────────────────────────────────
WORKER_SERVICE_URL=http://worker-service:8001
POLICY_SERVICE_URL=http://policy-service:8002
CLAIMS_SERVICE_URL=http://claims-service:8004
PAYMENT_SERVICE_URL=http://payment-service:8005
TRIGGER_SERVICE_URL=http://trigger-engine:8003
