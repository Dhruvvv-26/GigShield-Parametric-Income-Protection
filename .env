# ============================================================
# GigShield — Environment Variables
# Copy to .env and fill in your credentials
# ============================================================

# ── Database ──────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gigshield
DB_USER=gigshield
DB_PASSWORD=gigshield_secure_2026

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secure_2026

# ── Redpanda/Kafka ────────────────────────────────────────────
REDPANDA_BROKERS=redpanda:9092

# ── OpenWeatherMap (Trigger Engine — weather data) ────────────
# Get free key: https://openweathermap.org/api
OWM_API_KEY=cb2a63918460b8dbcff75147ea727f15
WAQI_API_KEY=dbb5b4fa605d51dcaf10a97e85344a6230b47b3e

# ── CPCB (Trigger Engine — AQI data) ─────────────────────────
# Indian govt pollution board, no key needed for basic access
CPCB_API_KEY=

# ── Razorpay (Payment Service — UPI payouts) ──────────────────
# Test mode keys from: https://dashboard.razorpay.com/app/keys
# Leave as 'demo_key' for simulated payouts (no real API calls)
RAZORPAY_KEY_ID=rzp_test_SXlxoGc4KsKJE7
RAZORPAY_KEY_SECRET=eMm0RoRjBhiuPuD0cCPyP63Q
RAZORPAY_ACCOUNT_NUMBER=2323230085726431
RAZORPAY_WEBHOOK_SECRET=change_me

# ── Firebase (Notification Service — FCM push) ────────────────
# Path to Firebase service account JSON file
# Leave empty for Redis-only push simulation
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase_service_account.json
FIREBASE_CREDENTIALS=
FCM_DISPATCH_ENABLED=false

# ── Grafana Dashboard ─────────────────────────────────────────
GRAFANA_PASSWORD=admin2026

# ── General ───────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── Worker App (React Native / Expo) ──────────────────────────
# Set to your machine's LAN IP for physical device testing
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2
