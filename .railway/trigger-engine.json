{
  "serviceName": "kavachai-trigger-engine",
  "dockerfilePath": "services/trigger_engine/Dockerfile.railway",
  "rootDirectory": ".",
  "healthcheckPath": "/health",
  "healthcheckTimeout": 300,
  "settings": {
    "port": 8003,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "envVars": {
    "PORT": "8003",
    "SERVICE_NAME": "trigger-engine",
    "SERVICE_PORT": "8003",
    "ENV": "production",
    "LOG_LEVEL": "INFO"
  }
}
