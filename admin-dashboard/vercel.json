{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_WORKER_URL": "https://placeholder.railway.app",
    "VITE_POLICY_URL": "https://placeholder.railway.app",
    "VITE_TRIGGER_URL": "https://placeholder.railway.app",
    "VITE_CLAIMS_URL": "https://placeholder.railway.app",
    "VITE_PAYMENT_URL": "https://placeholder.railway.app",
    "VITE_ML_URL": "https://placeholder.railway.app",
    "VITE_DEMO_MODE": "false"
  }
}
