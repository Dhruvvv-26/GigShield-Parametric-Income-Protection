# ── KavachAI Worker App — Environment Variables ──────────────
# Set API_HOST to your machine's LAN IP (e.g. 192.168.x.x)
EXPO_PUBLIC_API_HOST=192.168.x.x

# Worker & Policy IDs for demo
EXPO_PUBLIC_WORKER_ID=your_worker_id_here
EXPO_PUBLIC_POLICY_ID=your_policy_id_here

# Direct LAN service URLs (used when NOT tunneling)
EXPO_PUBLIC_WORKER_SERVICE=http://192.168.x.x:8001
EXPO_PUBLIC_POLICY_SERVICE=http://192.168.x.x:8002
EXPO_PUBLIC_TRIGGER_SERVICE=http://192.168.x.x:8003
EXPO_PUBLIC_CLAIMS_SERVICE=http://192.168.x.x:8004
EXPO_PUBLIC_PAYMENT_SERVICE=http://192.168.x.x:8005
EXPO_PUBLIC_ML_SERVICE=http://192.168.x.x:8006

# ── Tunnel Overrides (uncomment when using loca.lt tunnels) ──
# These OVERRIDE the direct service URLs above for claims & policy
# EXPO_PUBLIC_TUNNEL_CLAIMS=https://your-claims-tunnel.loca.lt
# EXPO_PUBLIC_TUNNEL_POLICY=https://your-policy-tunnel.loca.lt

# ── Supabase Auth ────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON=your_supabase_anon_key_here
