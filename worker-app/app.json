{
  "expo": {
    "name": "GigShield",
    "slug": "gigshield-worker",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "gigshield",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gigshield.worker",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GigShield needs your location to verify your zone for claim processing.",
        "NSLocationAlwaysUsageDescription": "GigShield uses background location for claim verification.",
        "NSMotionUsageDescription": "GigShield uses motion sensors for anti-fraud verification."
      }
    },
    "android": {
      "package": "com.gigshield.worker",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BODY_SENSORS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-sensors",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "gigshield-worker"
      }
    }
  }
}
