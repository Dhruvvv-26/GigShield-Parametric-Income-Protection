# ============================================================
# KavachAI — Payment Service — Railway Deployment Dockerfile
# Single-stage build optimized for Railway.app
# Build context: repo root (.)
# ============================================================

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app:/app/shared \
    PORT=8005

WORKDIR /app

# System dependencies: psycopg2, libgomp1 (LightGBM)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    gcc \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY ./services/payment_service/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && rm /tmp/requirements.txt

# Copy application code
COPY ./services/payment_service /app/
COPY ./shared /app/shared/

# Non-root user for security
RUN useradd -m -u 1001 kavachai && chown -R kavachai:kavachai /app
USER kavachai

EXPOSE 8005

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
    CMD curl -sf http://localhost:8005/health || exit 1

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8005", \
     "--workers", "1", "--log-level", "info", "--proxy-headers"]
